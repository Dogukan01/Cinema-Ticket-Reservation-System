# ============================================
# SBRS Backend - Ortam Değişkenleri Örneği
# ============================================
# Bu dosyayı kopyalayarak .env dosyası oluşturun:
# cp .env.example .env
#
# Ardından aşağıdaki değerleri gerçek değerlerle değiştirin.
# ============================================

# Çalışma Ortamı
NODE_ENV=development

# Sunucu Portu
PORT=3000

# ============================================
# PostgreSQL Veritabanı Konfigürasyonu
# ============================================
# NeonDB (Cloud) için tek satır:
DATABASE_URL='postgresql://KULLANICI:SIFRE@HOST/DB_ADI?sslmode=require'

# Yerel PostgreSQL için (Neon kullanmıyorsanız):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_secure_password_here
# DB_NAME=sbrs_db

# ============================================
# Redis Cache Konfigürasyonu
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT Kimlik Doğrulama
# ============================================
JWT_SECRET=SBRS_SUPER_SECRET_JWT_KEY_CHANGE_THIS_IN_PRODUCTION_12345

# ============================================
# Şifreleme Anahtarı
# ============================================
ENCRYPTION_KEY=your32characterencryptionkey123

# ============================================
# TMDB (The Movie Database) API
# ============================================
TMDB_API_KEY=your_tmdb_api_key_here

# ============================================
# SMTP (E-Posta Servisi) Konfigürasyonu
# ============================================
# E-posta göndermek için SMTP sunucusu bilgileri:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SBRS Cinema Club" <noreply@yourdomain.com>