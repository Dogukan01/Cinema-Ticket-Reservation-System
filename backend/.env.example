# ============================================
# SBRS Backend - Ortam Değişkenleri Örneği
# ============================================
# Bu dosyayı kopyalayarak .env dosyası oluşturun:
# cp .env.example .env
#
# Ardından aşağıdaki değerleri gerçek değerlerle değiştirin.
# ============================================

# Çalışma Ortamı
# development: Geliştirme ortamı (Debug modu açık, SSL kapalı)
# production: Üretim ortamı (SSL açık, optimizasyonlar aktif)
NODE_ENV=development

# Sunucu Konfigürasyonu
PORT=3000

# ============================================
# PostgreSQL Veritabanı Konfigürasyonu
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=sbrs_db

# ============================================
# Redis Cache Konfigürasyonu
# ============================================
# Local Redis için: redis://localhost:6379
# Redis şifresi varsa: redis://default:password@host:port
REDIS_URL=redis://localhost:6379

# ============================================
# JWT Kimlik Doğrulama
# ============================================
# JWT tokenlarını imzalamak için kullanılan gizli anahtar
# Production'da güçlü, random bir değer kullanın
# Oluşturma: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=SBRS_SUPER_SECRET_JWT_KEY_CHANGE_THIS_IN_PRODUCTION_12345

# ============================================
# Şifreleme Anahtarı
# ============================================
# Hassas verilerin şifrelenmesi için 32 karakter uzunluğunda bir anahtar
# Oluşturma: node -e "console.log(require('crypto').randomBytes(32).toString('hex').substring(0, 32))"
ENCRYPTION_KEY=your32characterencryptionkey123

# ============================================
# TMDB (The Movie Database) API
# ============================================
# https://www.themoviedb.org/settings/api adresinden ücretsiz API key alınabilir
# Filmler uygulamaya periyodik olarak senkronize edilir
TMDB_API_KEY=your_tmdb_api_key_here

# ============================================
# Loglama (İsteğe bağlı)
# ============================================
# LOG_LEVEL=info
# LOG_FILE=./logs/app.log

# ============================================
# Ödeme Gateway (İsteğe bağlı - Varsa)
# ============================================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# ============================================
# Email Konfigürasyonu (İsteğe bağlı)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# FROM_EMAIL=noreply@cinemabooking.com
